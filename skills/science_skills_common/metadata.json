      "skills/science_skills_common/http_client.py"
    ],
    "has_chinese_normalizer": false
  },
  "network": {
    "requires_network": false,
    "sources": []
  },
  "compliance": {
    "preserve_upstream_license": true,
    "upstream": {
      "name": "Google DeepMind science-skills",
      "repository": "https://github.com/google-deepmind/science-skills",
      "license": "Apache-2.0"
    }
  }
}
